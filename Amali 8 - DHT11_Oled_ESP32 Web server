/*
 * ESP32 Web Server - Suhu & Kelembapan DHT11
 * Menggunakan ESPAsyncWebServer + AsyncTCP
 */

#include <WiFi.h>
#include <ESPAsyncWebServer.h>
#include <DHT.h>

// ==================== TETAPAN ====================
// WiFi
const char* ssid = "Nama_WiFi_Kau";          // Ganti dengan SSID WiFi awak
const char* password = "Password_WiFi_Kau";  // Ganti dengan password WiFi

// DHT11
#define DHTPIN 14
#define DHTTYPE DHT11
DHT dht(DHTPIN, DHTTYPE);

// Web Server
AsyncWebServer server(80);

// Pembolehubah bacaan
float suhu = 0.0;
float kelembapan = 0.0;

// HTML Halaman Web
const char index_html[] PROGMEM = R"rawliteral(
<!DOCTYPE HTML>
<html>
<head>
  <title>ESP32 DHT11 Monitor</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body { font-family: Arial; text-align: center; background: #f0f0f0; }
    h1 { color: #0066cc; }
    .card { background: white; padding: 20px; margin: 20px auto; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); max-width: 400px; }
    .value { font-size: 2.5em; font-weight: bold; color: #0066cc; }
    .refresh { margin-top: 20px; padding: 10px 20px; font-size: 1em; }
  </style>
</head>
<body>
  <h1>ESP32 DHT11 Web Server</h1>
  
  <div class="card">
    <h2>Suhu Bilik</h2>
    <div class="value" id="suhu">--.-</div>
    <p>*C</p>
  </div>

  <div class="card">
    <h2>Kelembapan</h2>
    <div class="value" id="kelembapan">--.-</div>
    <p>%</p>
  </div>

  <button class="refresh" onclick="location.reload()">Refresh</button>

  <script>
    function updateData() {
      fetch('/data')
        .then(response => response.json())
        .then(data => {
          document.getElementById('suhu').textContent = data.suhu.toFixed(1);
          document.getElementById('kelembapan').textContent = data.kelembapan.toFixed(1);
        });
    }
    setInterval(updateData, 2000);  // Auto update setiap 2 saat
    window.onload = updateData;
  </script>
</body>
</html>
)rawliteral";

// =================================================
void setup() {
  Serial.begin(115200);
  dht.begin();

  // Sambung WiFi
  WiFi.begin(ssid, password);
  Serial.print("Menyambung ke WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Berjaya Disambung!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  // Route untuk halaman utama
  server.on("/", HTTP_GET, [](AsyncWebServerRequest *request){
    request->send_P(200, "text/html", index_html);
  });

  // Route untuk data JSON
  server.on("/data", HTTP_GET, [](AsyncWebServerRequest *request){
    String json = "{";
    json += "\"suhu\":" + String(suhu) + ",";
    json += "\"kelembapan\":" + String(kelembapan);
    json += "}";
    request->send(200, "application/json", json);
  });

  // Mula Web Server
  server.begin();
  Serial.println("ESP32 Web Server Dimulakan!");
}

void loop() {
  // Baca sensor setiap 2 saat
  static unsigned long lastRead = 0;
  if (millis() - lastRead > 2000) {
    suhu = dht.readTemperature();
    kelembapan = dht.readHumidity();
    
    if (isnan(suhu) || isnan(kelembapan)) {
      Serial.println("Ralat membaca DHT11!");
    } else {
      Serial.printf("Suhu: %.1f°C | Kelembapan: %.1f%%\n", suhu, kelembapan);
    }
    lastRead = millis();
  }
}
