/*
 * ESP32 Web Server DHT11 + WiFiManager
 * Auto captive portal untuk setup WiFi
 */

#include <WiFi.h>
#include <ESPAsyncWebServer.h>
#include <WiFiManager.h>      // https://github.com/tzapu/WiFiManager
#include <DHT.h>

// ==================== TETAPAN ====================
#define DHTPIN 14
#define DHTTYPE DHT11

DHT dht(DHTPIN, DHTTYPE);
AsyncWebServer server(80);

// =================================================

String readTemperature() {
  float t = dht.readTemperature();
  if (isnan(t)) return "--";
  return String(t, 1);
}

String readHumidity() {
  float h = dht.readHumidity();
  if (isnan(h)) return "--";
  return String(h, 1);
}

// HTML Web Page
const char index_html[] PROGMEM = R"rawliteral(
<!DOCTYPE HTML><html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ESP32 DHT11</title>
  <style>
    body { font-family: Arial; text-align: center; background: #f0f0f0; margin:0; }
    h1 { color: #0066cc; padding: 20px; }
    .card { background: white; margin: 20px auto; padding: 20px; border-radius: 15px; 
            box-shadow: 0 4px 8px rgba(0,0,0,0.1); max-width: 420px; }
    .value { font-size: 3.8rem; font-weight: bold; color: #0066cc; margin: 10px 0; }
    .label { font-size: 1.4rem; color: #555; }
  </style>
</head>
<body>
  <h1>ESP32 DHT11 Monitor</h1>
  
  <div class="card">
    <div class="label">Suhu Bilik</div>
    <div class="value" id="temp">--.-</div>
    <span>&deg;C</span>
  </div>

  <div class="card">
    <div class="label">Kelembapan</div>
    <div class="value" id="hum">--.-</div>
    <span>%</span>
  </div>

<script>
setInterval(() => {
  fetch('/temperature').then(r => r.text()).then(t => document.getElementById('temp').textContent = t);
}, 2000);

setInterval(() => {
  fetch('/humidity').then(r => r.text()).then(h => document.getElementById('hum').textContent = h);
}, 2000);
</script>
</body>
</html>
)rawliteral";

void setup() {
  Serial.begin(115200);
  dht.begin();

  // WiFiManager Setup
  WiFiManager wm;
  // wm.resetSettings();        // Uncomment untuk reset setting WiFi (guna sekali sahaja)

  Serial.println("Mencuba sambung WiFi...");
  bool res = wm.autoConnect("ESP32-DHT11-Setup", "12345678");  // SSID & Password captive portal

  if(!res) {
    Serial.println("Gagal sambung WiFi!");
    ESP.restart();
  } 
  else {
    Serial.println("WiFi Berjaya Disambung!");
    Serial.print("IP Address: ");
    Serial.println(WiFi.localIP());
  }

  // Web Server Routes
  server.on("/", HTTP_GET, [](AsyncWebServerRequest *request) {
    request->send_P(200, "text/html", index_html);
  });

  server.on("/temperature", HTTP_GET, [](AsyncWebServerRequest *request) {
    request->send(200, "text/plain", readTemperature().c_str());
  });

  server.on("/humidity", HTTP_GET, [](AsyncWebServerRequest *request) {
    request->send(200, "text/plain", readHumidity().c_str());
  });

  server.begin();
  Serial.println("Web Server Dah Mula!");
}

void loop() {
  delay(1000);
}
