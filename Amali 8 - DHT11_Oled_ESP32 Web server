#include <WiFi.h>
#include <ESPAsyncWebServer.h>
#include <DHT.h>

// ==================== TETAPAN ====================
const char* ssid = "Redmi13";           // GANTI DENGAN WIFI AWAK
const char* password = "ha.fiz123";   // GANTI

#define DHTPIN 14
#define DHTTYPE DHT11

DHT dht(DHTPIN, DHTTYPE);
AsyncWebServer server(80);

// =================================================

String readTemperature() {
  float t = dht.readTemperature();
  if (isnan(t)) {
    Serial.println("Ralat baca suhu!");
    return "--";
  }
  return String(t, 1);
}

String readHumidity() {
  float h = dht.readHumidity();
  if (isnan(h)) {
    Serial.println("Ralat baca kelembapan!");
    return "--";
  }
  return String(h, 1);
}

// ==================== HTML ====================
