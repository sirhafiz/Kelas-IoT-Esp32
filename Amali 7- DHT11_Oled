/*
 * Ujian Berasingan: Sensor Suhu & Kelembapan (DHT11) + OLED SSD1306
 * Objektif: Baca DHT11 dan papar di Serial Monitor + OLED
*install library : 
1. Library utama: Adafruit SSD1306
2. Library sokongan (wajib): Adafruit GFX Library
 */

#include <DHT.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// ---------------------------------------------------------
// TETAPAN SENSOR DHT11
// ---------------------------------------------------------
#define DHTPIN 14
#define DHTTYPE DHT11
DHT dht(DHTPIN, DHTTYPE);

// ---------------------------------------------------------
// TETAPAN OLED SSD1306 (128x64)
// ---------------------------------------------------------
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1          // Pin reset (biasanya -1 jika tiada)
#define OLED_ADDR 0x3C         // Alamat I2C OLED (paling biasa)
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

void setup() {
  Serial.begin(115200);
  
  // Inisialisasi DHT11
  dht.begin();
  
  // Inisialisasi OLED
  if(!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    Serial.println("Gagal memulakan OLED SSD1306!");
    while(1);  // Berhenti jika OLED gagal
  }
  
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(1);
  
  Serial.println("Sistem DHT11 + OLED Dimulakan...");
  
  // Paparan selamat datang di OLED
  display.setTextSize(2);
  display.setCursor(10, 20);
  display.println("DHT11 + OLED");
  display.display();
  delay(2000);
}

void loop() {
  float suhu = dht.readTemperature();
  float kelembapan = dht.readHumidity();

  // ---------------------------------------------------------
  // PAPARAN SERIAL MONITOR
  // ---------------------------------------------------------
  Serial.println("===============================");
  if (isnan(suhu) || isnan(kelembapan)) {
    Serial.println("Ralat: Gagal membaca sensor DHT11!");
  } else {
    Serial.print("Suhu Bilik : ");
    Serial.print(suhu);
    Serial.println(" *C");
    Serial.print("Kelembapan : ");
    Serial.print(kelembapan);
    Serial.println(" %");
  }
  Serial.println("===============================\n");

  // ---------------------------------------------------------
  // PAPARAN KE OLED
  // ---------------------------------------------------------
  display.clearDisplay();
  
  display.setTextSize(1);
  display.setCursor(0, 0);
  display.println("   DHT11 MONITOR");
  display.println("-------------------");

  if (isnan(suhu) || isnan(kelembapan)) {
    display.setTextSize(1);
    display.setCursor(10, 30);
    display.println("  Ralat Sensor!");
  } else {
    display.setTextSize(2);
    display.setCursor(0, 20);
    display.print(suhu, 1);
    display.println(" C");

    display.setCursor(0, 45);
    display.print(kelembapan, 1);
    display.println(" %");
  }

  display.display();

  delay(2000);  // Update setiap 2 saat
}
